<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>HTML Editor</title>
    <style>
        .annytab-form-button {
            display: inline-block;
            padding: 6px 20px 6px 20px;
            color: #000000;
            font-size: 16px;
            line-height: 16px;
            font-weight: bold;
            background-color: #ffffff;
            border: 1px solid #d9d9d9;
            margin: 10px 0px 0px 0px;
            cursor: pointer;
            vertical-align: middle;
        }
        .annytab-form-button:hover {
            background-color: #ddd;
            text-decoration: none;
        }
    </style>
</head>
<body style="width:100%;font-family:Arial, Helvetica, sans-serif;padding:20px;">

    @*Html*@
    <div>Textarea</div>
    <div id="htmlButtonPanel" style="width:1000px;border: 1px solid #808080;border-bottom: 0;background-color: #e9e9e9;padding: 0 10px 10px 10px;"></div>
    <textarea id="txtContents" name="txtContents" style="width:1000px;height:400px;padding:10px;border: 1px solid #808080;font-family:Arial;font-size:16px;line-height:24px;"></textarea>
    <div id="txtPreview" style="width:1000px;height:400px;padding:10px;border: 1px solid #808080;font-size:16px;line-height:24px;overflow:auto;" hidden></div>
    <br /><br />
    <input type="button" value="minify" onclick="panel.minify();" />

    @*Scripts*@
    <script src="/js/annytab.html.editor.js"></script>
    <script>

        var options = { button_container: 'htmlButtonPanel', textarea: 'txtContents', preview: 'txtPreview', button_class: 'annytab-form-button' };
        var panel = new annytab.html.editor(options);

    </script>

</body>
</html>